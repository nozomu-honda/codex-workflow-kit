{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nozomu-honda/codex-workflow-kit/schemas/chatgpt-automation.schema.json",
  "title": "ChatGPT automation config",
  "type": "object",
  "additionalProperties": true,
  "required": ["version", "baseBranch", "ciWorkflowName"],
  "properties": {
    "version": {
      "const": 1
    },
    "baseBranch": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._/-]*$"
    },
    "ciWorkflowName": {
      "type": "string",
      "pattern": "^(?=.*\\S)[^\\r\\n]+$"
    },
    "mergeMethod": {
      "enum": ["squash", "merge", "rebase"]
    },
    "dryRunDefault": {
      "type": "boolean",
      "default": true
    },
    "features": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "autoRequest": { "type": "boolean", "default": false },
        "routeReview": { "type": "boolean", "default": false },
        "autoMerge": { "type": "boolean", "default": false },
        "mainFollowup": { "type": "boolean", "default": false },
        "actionsApproval": { "type": "boolean", "default": false }
      }
    },
    "labels": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "needsChatGptReview": { "$ref": "#/$defs/nonEmptyString" },
        "reviewedByChatGpt": { "$ref": "#/$defs/nonEmptyString" },
        "needsCodexFix": { "$ref": "#/$defs/nonEmptyString" },
        "codexFixInProgress": { "$ref": "#/$defs/nonEmptyString" },
        "autoMergeAfterCi": { "$ref": "#/$defs/nonEmptyString" },
        "doNotMerge": { "$ref": "#/$defs/nonEmptyString" },
        "doNotAutoReviewRequest": { "$ref": "#/$defs/nonEmptyString" },
        "doNotAutoCodexFix": { "$ref": "#/$defs/nonEmptyString" },
        "doNotAutoCodexMainFollowup": { "$ref": "#/$defs/nonEmptyString" },
        "codexMainFollowupInProgress": { "$ref": "#/$defs/nonEmptyString" },
        "doNotAutoApproveActions": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "decisionMode": {
          "enum": ["marker-only", "trusted-actors"]
        },
        "trustedActors": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "markers": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "approved": { "$ref": "#/$defs/nonEmptyString" },
            "changesRequested": { "$ref": "#/$defs/nonEmptyString" },
            "reviewRequest": { "$ref": "#/$defs/nonEmptyString" },
            "ignoreInFencedCodeBlocks": { "const": true },
            "excludeReviewRequestComments": { "const": true }
          }
        },
        "decisions": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "stopOnLatestChangesRequested": { "const": true }
          }
        }
      }
    },
    "reviewRouting": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "dryRun": { "const": true },
        "allowedBaseBranches": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "acceptedTriggerTypes": {
          "type": "array",
          "items": { "$ref": "#/$defs/reviewRoutingTriggerType" }
        },
        "commands": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "requestLabels": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "reviewerNames": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "trustedHumanActors": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "trustedBotActors": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "allowDraft": { "type": "boolean", "default": false },
        "allowFork": { "const": false },
        "requireSameRepository": { "const": true },
        "requiredWorkflows": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "ignoredPathPatterns": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "sensitivePathPatterns": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "maxChangedFiles": { "type": "integer", "minimum": 1, "maximum": 500 },
        "maxAdditions": { "type": "integer", "minimum": 0, "maximum": 100000 },
        "maxDeletions": { "type": "integer", "minimum": 0, "maximum": 100000 },
        "cooldownSeconds": { "type": "integer", "minimum": 0, "maximum": 604800 },
        "duplicatePolicy": { "enum": ["dedupe-key", "allow-rerun"] }
      }
    },
    "autoMerge": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "dryRun": { "const": true },
        "mode": { "$ref": "#/$defs/autoMergeMode" },
        "mergeMethod": { "enum": ["squash", "merge", "rebase"] },
        "allowedBaseBranches": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "requireSameRepository": { "const": true },
        "allowFork": { "const": false },
        "requiredApprovals": { "type": "integer", "minimum": 0, "maximum": 20 },
        "allowBotApproval": { "type": "boolean", "default": false },
        "trustedReviewers": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "requiredWorkflows": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "requireResolvedThreads": { "type": "boolean", "default": true },
        "allowDraft": { "type": "boolean", "default": false },
        "sensitivePathPatterns": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "manualMergePathPatterns": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "maxChangedFiles": { "type": "integer", "minimum": 1, "maximum": 500 },
        "maxAdditions": { "type": "integer", "minimum": 0, "maximum": 100000 },
        "maxDeletions": { "type": "integer", "minimum": 0, "maximum": 100000 },
        "requireChatGPTReview": { "type": "boolean", "default": true },
        "requireHumanReview": { "type": "boolean", "default": false },
        "requireCurrentReview": { "type": "boolean", "default": true },
        "duplicatePolicy": { "enum": ["dedupe-key", "allow-rerun"] },
        "cooldownSeconds": { "type": "integer", "minimum": 0, "maximum": 604800 },
        "deleteBranchAfterMerge": { "const": false },
        "useMergeQueue": { "type": "boolean", "default": false }
      },
      "allOf": [
        {
          "if": {
            "properties": { "mode": { "const": "merge-queue" } },
            "required": ["mode"]
          },
          "then": {
            "properties": { "useMergeQueue": { "const": true } },
            "required": ["useMergeQueue"]
          }
        },
        {
          "if": {
            "properties": { "mode": { "const": "immediate-merge" } },
            "required": ["mode"]
          },
          "then": {
            "properties": { "requiredApprovals": { "type": "integer", "minimum": 1 } }
          }
        }
      ]
    },
    "protectedFiles": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "disableDefaults": { "const": false },
        "defaultHardBlockPatterns": false,
        "hardBlockPatterns": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "warningOnlyPatterns": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        }
      }
    },
    "secretLike": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "disableDefaults": { "const": false },
        "defaultHardBlockPatterns": false,
        "hardBlockPatterns": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "warningOnlyPatterns": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        }
      }
    },
    "queues": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "reviewFix": { "$ref": "#/$defs/queue" },
        "mainFollowup": { "$ref": "#/$defs/queue" }
      }
    },
    "codex": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "reviewFix": { "$ref": "#/$defs/codexAutoFix" },
        "mainFollowup": { "$ref": "#/$defs/codexAutoFix" }
      }
    },
    "schedules": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "reviewRequest": { "$ref": "#/$defs/schedule" },
        "autoMerge": { "$ref": "#/$defs/schedule" },
        "mainFollowup": { "$ref": "#/$defs/schedule" },
        "actionsApproval": { "$ref": "#/$defs/schedule" }
      }
    },
    "secrets": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "reviewRequestCommentToken": { "$ref": "#/$defs/envName" },
        "prBranchUpdateToken": { "$ref": "#/$defs/envName" },
        "autoMergeToken": { "$ref": "#/$defs/envName" },
        "actionsApproverToken": { "$ref": "#/$defs/envName" }
      }
    },
    "variables": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "codexTrigger": { "$ref": "#/$defs/envName" },
        "mainFollowupEnabled": { "$ref": "#/$defs/envName" },
        "reviewFixMaxAttempts": { "$ref": "#/$defs/envName" },
        "mainFollowupMaxAttempts": { "$ref": "#/$defs/envName" }
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "pattern": ".*\\S.*"
    },
    "envName": {
      "type": "string",
      "pattern": "^[A-Z_][A-Z0-9_]*$"
    },
    "cron": {
      "type": "string",
      "format": "github-actions-cron"
    },
    "reviewRoutingTriggerType": {
      "enum": [
        "ci-success",
        "trusted-review-command",
        "trusted-review-request",
        "manual-review-request",
        "label-request",
        "draft-ready",
        "pr-updated"
      ]
    },
    "autoMergeMode": {
      "enum": ["plan-only", "enable-auto-merge", "merge-queue", "immediate-merge"]
    },
    "queue": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "issueNumber": { "type": "integer", "minimum": 1 },
        "issueTitle": { "$ref": "#/$defs/nonEmptyString" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "enabled": { "const": true } },
            "required": ["enabled"]
          },
          "then": {
            "anyOf": [
              { "required": ["issueNumber"] },
              { "required": ["issueTitle"] }
            ]
          }
        }
      ]
    },
    "codexAutoFix": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "maxAttempts": { "type": "integer", "minimum": 1, "maximum": 10 },
        "sameRepoOnly": { "const": true },
        "allowDraft": { "type": "boolean", "default": false },
        "blockedLabel": { "$ref": "#/$defs/nonEmptyString" },
        "inProgressLabel": { "$ref": "#/$defs/nonEmptyString" },
        "triggerVariableName": { "$ref": "#/$defs/envName" }
      }
    },
    "schedule": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "cron": { "$ref": "#/$defs/cron" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "enabled": { "const": true } },
            "required": ["enabled"]
          },
          "then": {
            "required": ["cron"]
          }
        }
      ]
    }
  }
}
